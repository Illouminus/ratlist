# Local Supabase (ports shifted to 544xx — see supabase/config.toml).
# Production values are injected by Vercel as project env vars.
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=

# Sentry — optional, gated in main.tsx. Leave empty in local dev to
# keep the SDK silent.
VITE_SENTRY_DSN=
