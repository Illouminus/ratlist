# Local Supabase (ports shifted to 544xx — see supabase/config.toml).
# Production values are injected by Vercel as project env vars.
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=

# Sentry — optional, gated in main.tsx. Leave empty in local dev to
# keep the SDK silent.
VITE_SENTRY_DSN=

# Plausible — optional. When set, the production build injects the
# Plausible per-site loader script with this ID. The value is the
# unique identifier Plausible hands out in the "Install Plausible"
# step of site setup (find it in the install snippet they show, in
# the script src: https://plausible.io/js/<this-id>.js). Leave empty
# locally so dev pages don't pollute production stats.
# Example: VITE_PLAUSIBLE_SCRIPT_ID=pa-shRef6EUUr7_B4DMvcoSa
VITE_PLAUSIBLE_SCRIPT_ID=
