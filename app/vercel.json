{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/og.png",
      "destination": "https://fiuheufmawxkgbqddwwu.supabase.co/functions/v1/og-image"
    },
    { "source": "/share/:token", "destination": "/api/share/:token" },
    { "source": "/((?!assets/|legal/|share/|api/).*)", "destination": "/_spa.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
