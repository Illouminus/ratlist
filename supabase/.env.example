# Supabase Edge Function environment variables.
# Copy this file to supabase/.env (gitignored) and fill in real values for
# local development. For production, set these in the Supabase dashboard under
# Project Settings → Edge Functions → Secrets.

# ── Mangopay ──────────────────────────────────────────────────────────────────
# Sandbox credentials from https://hub.mangopay.com → Sandbox → API credentials
# Switch to 'production' and prod credentials before going live.
MANGOPAY_ENV=sandbox
MANGOPAY_CLIENT_ID=
MANGOPAY_API_KEY=
# Webhook secret — set in Mangopay dashboard → Webhooks → Signing secret.
# Used by the cagnotte-webhook Edge Function (Phase 4) to verify HMAC-SHA256
# signatures on inbound webhook calls.
MANGOPAY_WEBHOOK_SECRET=
